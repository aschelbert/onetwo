{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noai, noimageai"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/login", "destination": "/app.html" },
    { "source": "/reset-password", "destination": "/app.html" },
    { "source": "/dashboard", "destination": "/app.html" },
    { "source": "/financial", "destination": "/app.html" },
    { "source": "/issues", "destination": "/app.html" },
    { "source": "/building", "destination": "/app.html" },
    { "source": "/compliance", "destination": "/app.html" },
    { "source": "/archives", "destination": "/app.html" },
    { "source": "/voting", "destination": "/app.html" },
    { "source": "/boardroom", "destination": "/app.html" },
    { "source": "/community", "destination": "/app.html" },
    { "source": "/my-unit", "destination": "/app.html" },
    { "source": "/account", "destination": "/app.html" },
    { "source": "/support", "destination": "/app.html" },
    { "source": "/subscription", "destination": "/app.html" },
    { "source": "/admin/:path*", "destination": "/app.html" },
    { "source": "/demo", "destination": "/demo.html" }
  ]
}
